# Deny PHP execution in uploads directory
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Remove PHP handler for all files
RemoveHandler .php .phtml .php3 .php4 .php5 .php7
RemoveType .php .phtml .php3 .php4 .php5 .php7

# Deny access to .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>
